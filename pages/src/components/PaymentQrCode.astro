---
const { buttonLabel = "永久授权" } = Astro.props;
const modalId = 'payment-modal-' + Math.random().toString(36).substr(2, 9);
---

<div class="payment-wrapper">
  <button type="button" class="btn btn-primary payment-btn" data-payment-trigger data-modal-id={modalId}>
    {buttonLabel}
  </button>
</div>

<!-- 使用 Fragment 将弹框内容渲染到 body 级别 -->
<template data-payment-modal-template={modalId}>
  <div class="modal-overlay" data-modal-overlay={modalId} style="display: none;">
    <div class="modal-content">
      <div class="modal-header">
        <h3>企业赞助支持</h3>
        <button type="button" class="close-btn" data-close-modal>×</button>
      </div>
      <div class="modal-body">
        <p class="modal-subtitle">赞助 5000 元支持 Feat 开源项目，获取企业级服务与商业授权</p>
        
        <div class="qr-container">
          <div class="qr-item-pay">
            <div class="qr-img-box">
              <img src="https://smartboot.tech/wx_pay.png" alt="微信支付" loading="lazy" />
            </div>
            <span class="qr-tag wx">微信支付</span>
          </div>
          
          <div class="qr-item-pay">
            <div class="qr-img-box">
              <img src="https://smartboot.tech/ali_pay.png" alt="支付宝" loading="lazy" />
            </div>
            <span class="qr-tag ali">支付宝</span>
          </div>
          
          <div class="qr-divider"></div>
          
          <div class="qr-item-friend">
            <div class="qr-img-box large">
              <img src="https://smartboot.tech/img/qrcode/personal_wx.png" alt="加微信好友" loading="lazy" />
            </div>
            <div class="friend-info">
              <span class="qr-tag friend">加好友获取服务</span>
              <span class="note-text">备注：Feat企业赞助</span>
            </div>
          </div>
        </div>
        
        <div class="modal-footer">
          <span class="price-tag">¥5000 企业赞助</span>
          <span class="step-hint">① 扫码赞助 → ② 加微信好友 → ③ 获取商业授权与服务支持</span>
        </div>
      </div>
    </div>
  </div>
</template>

<style>
  .payment-wrapper {
    width: 100%;
  }
  
  .payment-btn {
    width: 100%;
    padding: 0.875rem 1.5rem;
    border-radius: 10px;
    font-weight: 500;
    font-size: 0.95rem;
    cursor: pointer;
    border: none;
    background: linear-gradient(135deg, #ea580c 0%, #f97316 100%);
    color: white;
    box-shadow: 0 4px 14px rgba(234, 88, 12, 0.25);
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .payment-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(234, 88, 12, 0.35);
  }

  /* 使用 :global 确保样式应用到 body 级别的弹框 */
  :global(.modal-overlay) {
    position: fixed;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.6);
    z-index: 10000;
    display: none;
    justify-content: center;
    align-items: center;
    padding: 1rem;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  :global(.modal-overlay.active) {
    display: flex;
  }

  :global(.modal-content) {
    background: white;
    border-radius: 16px;
    width: 100%;
    max-width: 700px;
    max-height: 90vh;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    animation: modalSlideIn 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  @keyframes modalSlideIn {
    from {
      opacity: 0;
      transform: translateY(-20px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  :global(.modal-header) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid #e2e8f0;
    background: #f8fafc;
  }

  :global(.modal-header h3) {
    margin: 0;
    color: #1e293b;
    font-size: 1.25rem;
    font-weight: 600;
  }

  :global(.close-btn) {
    background: none;
    border: none;
    font-size: 1.75rem;
    cursor: pointer;
    color: #64748b;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    transition: all 0.2s ease;
    line-height: 1;
    padding: 0;
  }

  :global(.close-btn:hover) {
    background: #e2e8f0;
    color: #1e293b;
  }

  :global(.modal-body) {
    padding: 1.25rem;
    overflow-y: auto;
    max-height: calc(90vh - 60px);
  }

  /* 副标题 */
  :global(.modal-subtitle) {
    text-align: center;
    color: #64748b;
    font-size: 0.9375rem;
    margin: 0 0 1.25rem;
  }

  /* 紧凑二维码容器 */
  :global(.qr-container) {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  /* 支付二维码项 */
  :global(.qr-item-pay) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  /* 好友二维码项 */
  :global(.qr-item-friend) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  /* 二维码图片容器 */
  :global(.qr-img-box) {
    width: 160px;
    height: 160px;
    border-radius: 8px;
    overflow: hidden;
    background: white;
    border: 1px solid #e2e8f0;
  }

  :global(.qr-img-box.large) {
    width: 180px;
    height: 180px;
  }

  :global(.qr-img-box img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* 分隔线 */
  :global(.qr-divider) {
    width: 1px;
    height: 110px;
    background: linear-gradient(180deg, transparent, #e2e8f0, transparent);
    align-self: center;
    margin: 0 0.25rem;
  }

  /* 标签样式 */
  :global(.qr-tag) {
    font-size: 0.8125rem;
    font-weight: 500;
    padding: 0.25rem 0.625rem;
    border-radius: 4px;
    white-space: nowrap;
  }

  :global(.qr-tag.wx) {
    background: #22c55e;
    color: white;
  }

  :global(.qr-tag.ali) {
    background: #3b82f6;
    color: white;
  }

  :global(.qr-tag.friend) {
    background: #f97316;
    color: white;
  }

  /* 好友信息 */
  :global(.friend-info) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
  }

  :global(.note-text) {
    font-size: 0.75rem;
    color: #64748b;
  }

  /* 底部信息 */
  :global(.modal-footer) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid #e2e8f0;
  }

  :global(.price-tag) {
    font-size: 1.25rem;
    font-weight: 700;
    color: #ea580c;
  }

  :global(.step-hint) {
    font-size: 0.8125rem;
    color: #64748b;
  }

  /* 平板响应式 */
  @media (max-width: 640px) {
    :global(.modal-content) {
      max-width: 95vw;
      margin: 1rem;
    }

    :global(.modal-body) {
      padding: 1rem;
    }

    :global(.qr-container) {
      gap: 0.75rem;
    }

    :global(.qr-img-box) {
      width: 130px;
      height: 130px;
    }

    :global(.qr-img-box.large) {
      width: 150px;
      height: 150px;
    }

    :global(.qr-divider) {
      height: 120px;
      margin: 0 0.25rem;
    }

    :global(.qr-tag) {
      font-size: 0.75rem;
      padding: 0.25rem 0.625rem;
    }

    :global(.note-text) {
      font-size: 0.75rem;
    }
  }

  /* 手机响应式 */
  @media (max-width: 400px) {
    :global(.modal-content) {
      margin: 0.5rem;
      border-radius: 12px;
    }

    :global(.modal-subtitle) {
      font-size: 0.875rem;
      margin-bottom: 1rem;
    }

    :global(.qr-container) {
      flex-wrap: wrap;
      gap: 1rem;
    }

    :global(.qr-divider) {
      display: none;
    }

    :global(.qr-img-box) {
      width: 120px;
      height: 120px;
    }

    :global(.qr-img-box.large) {
      width: 140px;
      height: 140px;
    }

    :global(.price-tag) {
      font-size: 1.125rem;
    }

    :global(.step-hint) {
      font-size: 0.75rem;
      text-align: center;
    }
  }
</style>

<script is:inline>
  (function() {
    // 确保只在页面加载完成后执行一次
    if (window.__paymentModalInitialized) return;
    window.__paymentModalInitialized = true;
    
    // 将所有弹框模板的 HTML 移动到 body 末尾
    const initModals = function() {
      document.querySelectorAll('[data-payment-modal-template]').forEach(function(template) {
        const modalId = template.getAttribute('data-payment-modal-template');
        const modalHtml = template.innerHTML;
        
        // 创建容器并插入到 body 末尾
        var container = document.createElement('div');
        container.innerHTML = modalHtml;
        container.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:0;overflow:visible;z-index:10000;';
        document.body.appendChild(container);
        
        // 存储引用
        var overlay = container.querySelector('[data-modal-overlay]');
        if (overlay) {
          overlay.removeAttribute('data-modal-overlay');
          overlay.setAttribute('data-modal-overlay-id', modalId);
        }
        
        // 移除模板
        template.remove();
      });
      
      // 绑定事件
      bindEvents();
    };
    
    const bindEvents = function() {
      // 触发按钮事件
      document.querySelectorAll('[data-payment-trigger]').forEach(function(trigger) {
        trigger.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          
          var modalId = trigger.getAttribute('data-modal-id');
          var overlay = document.querySelector('[data-modal-overlay-id="' + modalId + '"]');
          
          if (overlay) {
            overlay.style.display = 'flex';
            void overlay.offsetHeight; // 强制重绘
            overlay.classList.add('active');
            document.body.style.overflow = 'hidden';
            var scrollbarWidth = window.innerWidth - document.documentElement.clientWidth;
            if (scrollbarWidth > 0) {
              document.body.style.paddingRight = scrollbarWidth + 'px';
            }
          }
        });
      });
      
      // 关闭按钮和遮罩点击事件（使用事件委托）
      document.addEventListener('click', function(e) {
        var closeBtn = e.target.closest('[data-close-modal]');
        var overlay = e.target.closest('.modal-overlay.active');
        
        if (closeBtn) {
          e.preventDefault();
          e.stopPropagation();
          var activeOverlay = closeBtn.closest('.modal-overlay');
          if (activeOverlay) {
            closeModal(activeOverlay);
          }
        } else if (overlay && e.target === overlay) {
          closeModal(overlay);
        }
      });
      
      // ESC 键关闭
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          var activeOverlay = document.querySelector('.modal-overlay.active');
          if (activeOverlay) {
            closeModal(activeOverlay);
          }
        }
      });
    };
    
    var closeModal = function(overlay) {
      overlay.classList.remove('active');
      setTimeout(function() {
        if (!overlay.classList.contains('active')) {
          overlay.style.display = 'none';
        }
      }, 300);
      document.body.style.overflow = '';
      document.body.style.paddingRight = '';
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initModals);
    } else {
      initModals();
    }
  })();
</script>
