---
// LicenseGenerator.astro - Feat Cloud AOT License 生成器
---

<div class="license-generator">
    <div class="generator-header">
        <h2>License 生成器</h2>
        <p>为已赞助的企业/组织生成 Feat Cloud AOT 编译 License</p>
    </div>

    <div class="form-section">
        <div class="form-group">
            <label for="licenseName">名称</label>
            <input 
                type="text" 
                id="licenseName" 
                placeholder="请输入企业/组织名称"
            />
        </div>

        <div class="form-group">
            <label for="licenseNumber">编号</label>
            <div class="input-row">
                <input 
                    type="text" 
                    id="licenseNumber" 
                    placeholder="企业统一社会信用代码或自定义编号"
                />
                <button id="autoGenerateBtn" class="btn-auto">自动生成</button>
            </div>
            <div class="input-hint">
                示例：<code data-copy="91110000123456789X">91110000123456789X</code>（统一社会信用代码）
                <code data-copy="20250101000001">20250101000001</code>（时间戳编号）
            </div>
        </div>

        <div class="form-actions">
            <button id="generateBtn" class="btn-primary">生成 License</button>
        </div>
    </div>

    <div class="results-section" id="resultsSection" style="display: none;">
        <div class="result-block">
            <h3>feat.yml 配置</h3>
            <div class="code-wrapper">
                <pre id="featYmlConfig" class="code-block"></pre>
                <button class="copy-btn" data-target="featYmlConfig">复制</button>
            </div>
        </div>

        <div class="result-block">
            <h3>环境变量配置 <span class="badge">推荐</span></h3>
            <div class="tabs">
                <button class="tab active" data-tab="linux">Linux/macOS</button>
                <button class="tab" data-tab="windows-cmd">Windows CMD</button>
                <button class="tab" data-tab="windows-ps">PowerShell</button>
            </div>
            <div class="tab-content">
                <div class="tab-pane active" id="linux-pane">
                    <div class="code-wrapper">
                        <pre class="code-block">export FEAT_LICENSE="<span id="licenseEnvExample"></span>"</pre>
                        <button class="copy-btn" data-env="linux">复制</button>
                    </div>
                    <p class="note">添加到 ~/.bashrc 或 ~/.zshrc 永久生效</p>
                </div>
                <div class="tab-pane" id="windows-cmd-pane">
                    <div class="code-wrapper">
                        <pre class="code-block">set FEAT_LICENSE=<span id="licenseEnvExample2"></span></pre>
                        <button class="copy-btn" data-env="cmd">复制</button>
                    </div>
                    <p class="note">通过"系统属性" → "环境变量"设置永久生效</p>
                </div>
                <div class="tab-pane" id="windows-ps-pane">
                    <div class="code-wrapper">
                        <pre class="code-block">$env:FEAT_LICENSE="<span id="licenseEnvExample3"></span>"</pre>
                        <button class="copy-btn" data-env="ps">复制</button>
                    </div>
                    <p class="note">通过系统环境变量设置永久生效</p>
                </div>
            </div>
        </div>

        <div class="result-block highlight">
            <h3>提交至官方仓库</h3>
            <p class="block-desc">请将以下配置发送给管理员，用于添加到 Feat 官方仓库</p>
            <div class="code-wrapper">
                <pre id="featUsersConfig" class="code-block"></pre>
                <button class="copy-btn" data-target="featUsersConfig">复制</button>
            </div>
        </div>
    </div>
</div>

<script>
import { ec as EC } from 'elliptic';

class LicenseGenerator {
    constructor() {
        this.ec = new EC('p256');
        this.keyPair = null;
        this.signature = null;
        this.licenseName = '';
        this.licenseNumber = '';
        
        this.initEventListeners();
    }

    initEventListeners() {
        document.getElementById('generateBtn')?.addEventListener('click', () => this.generateLicense());
        document.getElementById('autoGenerateBtn')?.addEventListener('click', () => this.generateLicenseNumber());
        
        document.querySelectorAll('.tab').forEach(tab => {
            tab.addEventListener('click', (e) => this.switchTab(e.target));
        });
        
        document.querySelectorAll('.copy-btn').forEach(btn => {
            btn.addEventListener('click', (e) => this.copyToClipboard(e.currentTarget));
        });
        
        document.querySelectorAll('.input-hint code').forEach(code => {
            code.addEventListener('click', (e) => {
                const input = document.getElementById('licenseNumber');
                if (input) {
                    input.value = e.target.dataset.copy;
                    input.focus();
                }
            });
        });
        
        document.getElementById('licenseName')?.addEventListener('input', (e) => {
            this.licenseName = e.target.value;
        });
        
        document.getElementById('licenseNumber')?.addEventListener('input', (e) => {
            this.licenseNumber = e.target.value;
        });
    }

    switchTab(clickedTab) {
        const tabId = clickedTab.dataset.tab;
        
        clickedTab.parentElement.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        clickedTab.classList.add('active');
        
        clickedTab.closest('.tab-content').querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
        document.getElementById(`${tabId}-pane`).classList.add('active');
    }

    async copyToClipboard(btn) {
        let text = '';
        const targetId = btn.dataset.target;
        const envType = btn.dataset.env;
        
        if (targetId) {
            text = document.getElementById(targetId)?.textContent || '';
        } else if (envType) {
            const license = this.licenseNumber + '_' + this.publicKeyBase64;
            if (envType === 'linux' || envType === 'ps') {
                text = (envType === 'linux' ? 'export' : '$env:') + `FEAT_LICENSE="${license}"`;
            } else {
                text = `set FEAT_LICENSE=${license}`;
            }
        }
        
        if (!text) return;
        
        try {
            await navigator.clipboard.writeText(text);
            const originalText = btn.textContent;
            btn.textContent = '已复制';
            btn.classList.add('copied');
            setTimeout(() => {
                btn.textContent = originalText;
                btn.classList.remove('copied');
            }, 1500);
        } catch (err) {
            console.error('复制失败:', err);
        }
    }

    generateLicenseNumber() {
        const now = new Date();
        this.licenseNumber = `${now.getFullYear()}${String(now.getMonth() + 1).padStart(2, '0')}${String(now.getDate()).padStart(2, '0')}${String(now.getHours()).padStart(2, '0')}${String(now.getMinutes()).padStart(2, '0')}${String(now.getSeconds()).padStart(2, '0')}`;
        
        const input = document.getElementById('licenseNumber');
        if (input) {
            input.value = this.licenseNumber;
        }
    }

    async generateLicense() {
        const nameInput = document.getElementById('licenseName');
        const numberInput = document.getElementById('licenseNumber');
        
        this.licenseName = nameInput?.value?.trim() || '';
        this.licenseNumber = numberInput?.value?.trim() || '';

        if (!this.licenseName) {
            nameInput?.focus();
            return;
        }
        
        if (!this.licenseNumber) {
            numberInput?.focus();
            return;
        }

        const btn = document.getElementById('generateBtn');
        btn.disabled = true;
        btn.textContent = '生成中...';

        try {
            this.keyPair = this.ec.genKeyPair();
            const publicKeyDER = this.getPublicKeyDER();
            this.publicKeyBase64 = this.arrayBufferToBase64(publicKeyDER);
            const messageBytes = new TextEncoder().encode(this.licenseName);
            const messageHash = await crypto.subtle.digest('SHA-256', messageBytes);
            this.signature = this.keyPair.sign(Array.from(new Uint8Array(messageHash)));
            const signatureBase64 = this.signatureToBase64(this.signature);

            this.displayResults(signatureBase64);
        } catch (error) {
            console.error('License 生成失败:', error);
            alert('License 生成失败: ' + error.message);
        } finally {
            btn.disabled = false;
            btn.textContent = '生成 License';
        }
    }

    getPublicKeyDER() {
        const publicKeyPoint = this.keyPair.getPublic();
        const x = publicKeyPoint.getX().toArray('be', 32);
        const y = publicKeyPoint.getY().toArray('be', 32);
        
        const algorithmIdentifier = new Uint8Array([
            0x30, 0x13,
            0x06, 0x07, 0x2a, 0x86, 0x48, 0xce, 0x3d, 0x02, 0x01,
            0x06, 0x08, 0x2a, 0x86, 0x48, 0xce, 0x3d, 0x03, 0x01, 0x07
        ]);
        
        const publicKeyBytes = new Uint8Array([0x04, ...x, ...y]);
        const bitString = new Uint8Array([0x03, publicKeyBytes.length + 1, 0x00, ...publicKeyBytes]);
        
        return new Uint8Array([
            0x30, algorithmIdentifier.length + bitString.length,
            ...algorithmIdentifier,
            ...bitString
        ]);
    }

    signatureToBase64(signature) {
        const r = signature.r.toArray('be');
        const s = signature.s.toArray('be');
        
        const derSig = new Uint8Array([
            0x30, r.length + s.length + 4,
            0x02, r.length, ...r,
            0x02, s.length, ...s
        ]);
        
        return this.arrayBufferToBase64(derSig);
    }

    arrayBufferToBase64(buffer) {
        const bytes = new Uint8Array(buffer);
        let binary = '';
        for (let i = 0; i < bytes.byteLength; i++) {
            binary += String.fromCharCode(bytes[i]);
        }
        return btoa(binary);
    }

    displayResults(signatureBase64) {
        const featUsersConfig = `users:
  ${this.licenseNumber}:
    name: ${this.licenseName}
    license: ${signatureBase64}`;

        const featYmlConfig = `license: ${this.licenseNumber}_${this.publicKeyBase64}`;
        const licenseEnvExample = `${this.licenseNumber}_${this.publicKeyBase64}`;

        document.getElementById('featUsersConfig').textContent = featUsersConfig;
        document.getElementById('featYmlConfig').textContent = featYmlConfig;
        
        document.querySelectorAll('#licenseEnvExample, #licenseEnvExample2, #licenseEnvExample3').forEach(el => {
            el.textContent = licenseEnvExample;
        });
        
        const resultsSection = document.getElementById('resultsSection');
        resultsSection.style.display = 'block';
        resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
}

document.addEventListener('DOMContentLoaded', () => {
    new LicenseGenerator();
});
</script>

<style>
.license-generator {
    max-width: 800px;
    margin: 0 auto;
}

.generator-header {
    text-align: center;
    margin-bottom: 2rem;
}

.generator-header h2 {
    font-size: 1.5rem;
    font-weight: 600;
    color: #1e293b;
    margin: 0 0 0.5rem;
}

.generator-header p {
    color: #64748b;
    font-size: 0.9rem;
    margin: 0;
}

.form-section {
    background: white;
    border-radius: 8px;
    padding: 1.5rem;
    border: 1px solid #e2e8f0;
    margin-bottom: 1.5rem;
}

.form-group {
    margin-bottom: 1.25rem;
}

.form-group:last-of-type {
    margin-bottom: 0;
}

.form-group label {
    display: block;
    font-weight: 500;
    color: #374151;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
}

.form-group input {
    width: 100%;
    padding: 0.625rem 0.875rem;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 0.9rem;
    box-sizing: border-box;
}

.form-group input:focus {
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
}

.input-row {
    display: flex;
    gap: 0.5rem;
}

.input-row input {
    flex: 1;
}

.btn-auto {
    padding: 0.625rem 1rem;
    background: #f3f4f6;
    color: #374151;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 0.85rem;
    cursor: pointer;
    white-space: nowrap;
}

.btn-auto:hover {
    background: #e5e7eb;
}

.input-hint {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: #6b7280;
}

.input-hint code {
    background: #f3f4f6;
    padding: 0.125rem 0.375rem;
    border-radius: 3px;
    font-family: monospace;
    color: #3b82f6;
    cursor: pointer;
    margin: 0 0.25rem;
}

.input-hint code:hover {
    background: #e5e7eb;
}

.form-actions {
    margin-top: 1.5rem;
    text-align: center;
}

.btn-primary {
    padding: 0.75rem 2rem;
    background: #3b82f6;
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
}

.btn-primary:hover {
    background: #2563eb;
}

.btn-primary:disabled {
    opacity: 0.7;
    cursor: not-allowed;
}

.results-section {
    animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

.result-block {
    background: white;
    border-radius: 8px;
    padding: 1.25rem;
    border: 1px solid #e2e8f0;
    margin-bottom: 1rem;
}

.result-block:last-child {
    margin-bottom: 0;
}

.result-block h3 {
    font-size: 0.95rem;
    font-weight: 600;
    color: #1e293b;
    margin: 0 0 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.badge {
    background: #dbeafe;
    color: #1d4ed8;
    padding: 0.125rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 500;
}

.block-desc {
    font-size: 0.85rem;
    color: #6b7280;
    margin: 0 0 0.75rem;
}

.code-wrapper {
    position: relative;
}

.code-block {
    background: #1e293b;
    color: #e2e8f0;
    padding: 0.875rem;
    border-radius: 6px;
    font-family: monospace;
    font-size: 0.85rem;
    line-height: 1.5;
    overflow-x: auto;
    margin: 0;
}

.copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.25rem 0.625rem;
    background: rgba(255, 255, 255, 0.1);
    color: #e2e8f0;
    border: none;
    border-radius: 4px;
    font-size: 0.75rem;
    cursor: pointer;
}

.copy-btn:hover {
    background: rgba(255, 255, 255, 0.2);
}

.copy-btn.copied {
    background: #10b981;
    color: white;
}

.tabs {
    display: flex;
    gap: 0.25rem;
    margin-bottom: 0.75rem;
    background: #f3f4f6;
    padding: 0.25rem;
    border-radius: 6px;
}

.tab {
    flex: 1;
    padding: 0.5rem;
    background: transparent;
    border: none;
    border-radius: 4px;
    font-size: 0.8rem;
    color: #6b7280;
    cursor: pointer;
}

.tab:hover {
    color: #374151;
}

.tab.active {
    background: white;
    color: #1e293b;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
}

.tab-content {
    position: relative;
}

.tab-pane {
    display: none;
}

.tab-pane.active {
    display: block;
}

.note {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: #6b7280;
}

.highlight {
    background: #fffbeb;
    border-color: #fcd34d;
}

.highlight .code-block {
    border: 1px solid #f59e0b;
}

@media (max-width: 640px) {
    .input-row {
        flex-direction: column;
    }
    
    .btn-auto {
        width: 100%;
    }
    
    .tabs {
        flex-direction: column;
    }
}
</style>
