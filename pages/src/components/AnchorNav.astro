---
const navItems = [
  { id: 'hero', label: '首页', icon: 'home' },
  { id: 'features', label: '特色', icon: 'features' },
  { id: 'performance', label: '性能', icon: 'performance' },
  { id: 'pricing', label: '协议', icon: 'pricing' },
  { id: 'ecosystem', label: '生态', icon: 'ecosystem' },
];

const icons = {
  home: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  features: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>`,
  performance: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
  pricing: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`,
  ecosystem: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/></svg>`,
};
---

<nav class="anchor-nav" id="anchor-nav">
  <div class="nav-container">
    {navItems.map((item, index) => (
      <a 
        href={`#${item.id}`} 
        class="nav-item" 
        data-target={item.id}
        title={item.label}
      >
        <span class="nav-icon" set:html={icons[item.icon]}></span>
        <span class="nav-label">{item.label}</span>
        <span class="nav-indicator"></span>
      </a>
    ))}
  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const nav = document.getElementById('anchor-nav');
    const navItems = document.querySelectorAll('.nav-item');
    const sections = ['hero', 'features', 'performance', 'pricing', 'ecosystem'];
    
    let isScrolling = false;
    let scrollTimeout: number;
    
    navItems.forEach(item => {
      item.addEventListener('click', (e) => {
        e.preventDefault();
        const targetId = item.getAttribute('data-target');
        const target = document.getElementById(targetId || '');
        
        if (target) {
          isScrolling = true;
          navItems.forEach(n => n.classList.remove('active'));
          item.classList.add('active');
          
          target.scrollIntoView({ behavior: 'smooth' });
          
          clearTimeout(scrollTimeout);
          scrollTimeout = window.setTimeout(() => {
            isScrolling = false;
          }, 1000);
        }
      });
    });
    
    const observerOptions = {
      root: null,
      rootMargin: '-20% 0px -60% 0px',
      threshold: 0
    };
    
    const observer = new IntersectionObserver((entries) => {
      if (isScrolling) return;
      
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          navItems.forEach(item => {
            if (item.getAttribute('data-target') === id) {
              item.classList.add('active');
            } else {
              item.classList.remove('active');
            }
          });
        }
      });
    }, observerOptions);
    
    sections.forEach(id => {
      const section = document.getElementById(id);
      if (section) {
        observer.observe(section);
      }
    });
    
    let lastScrollY = window.scrollY;
    let ticking = false;
    
    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          if (window.scrollY > 300) {
            nav?.classList.add('visible');
          } else {
            nav?.classList.remove('visible');
          }
          ticking = false;
        });
        ticking = true;
      }
    });
    
    if (window.scrollY > 300) {
      nav?.classList.add('visible');
    }
  });
</script>

<style>
  .anchor-nav {
    position: fixed;
    right: 1.5rem;
    top: 50%;
    transform: translateY(-50%) translateX(100px);
    z-index: 100;
    opacity: 0;
    visibility: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .anchor-nav.visible {
    transform: translateY(-50%) translateX(0);
    opacity: 1;
    visibility: visible;
  }

  .nav-container {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    border-radius: 12px;
    padding: 0.5rem;
    box-shadow: 
      0 4px 20px rgba(0, 0, 0, 0.08),
      0 0 0 1px rgba(0, 0, 0, 0.04);
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.625rem 0.75rem;
    text-decoration: none;
    color: #64748b;
    border-radius: 8px;
    transition: all 0.25s ease;
    position: relative;
    cursor: pointer;
  }
  
  .nav-item:hover {
    background: #f1f5f9;
    color: #1e293b;
  }
  
  .nav-item.active {
    background: linear-gradient(135deg, rgba(234, 88, 12, 0.1) 0%, rgba(249, 115, 22, 0.08) 100%);
    color: #ea580c;
  }
  
  .nav-item.active .nav-indicator {
    opacity: 1;
    transform: scaleY(1);
  }

  .nav-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .nav-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .nav-label {
    font-size: 0.8rem;
    font-weight: 500;
    white-space: nowrap;
  }
  
  .nav-indicator {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%) scaleY(0);
    width: 3px;
    height: 60%;
    background: #ea580c;
    border-radius: 0 2px 2px 0;
    opacity: 0;
    transition: all 0.25s ease;
  }

  @media (max-width: 1024px) {
    .anchor-nav {
      right: 0.75rem;
    }
    
    .nav-container {
      padding: 0.375rem;
    }
    
    .nav-item {
      padding: 0.5rem 0.625rem;
      gap: 0.5rem;
    }
    
    .nav-icon {
      width: 16px;
      height: 16px;
    }
    
    .nav-label {
      font-size: 0.75rem;
    }
  }

  @media (max-width: 768px) {
    .anchor-nav {
      bottom: 1rem;
      right: 50%;
      top: auto;
      transform: translateX(50%) translateY(100px);
    }
    
    .anchor-nav.visible {
      transform: translateX(50%) translateY(0);
    }
    
    .nav-container {
      flex-direction: row;
      padding: 0.375rem;
      gap: 0.125rem;
    }
    
    .nav-item {
      flex-direction: column;
      padding: 0.5rem 0.625rem;
      gap: 0.25rem;
    }
    
    .nav-label {
      font-size: 0.65rem;
    }
    
    .nav-indicator {
      left: 50%;
      top: auto;
      bottom: 0;
      width: 60%;
      height: 2px;
      transform: translateX(-50%) scaleX(0);
      border-radius: 2px 2px 0 0;
    }
    
    .nav-item.active .nav-indicator {
      transform: translateX(-50%) scaleX(1);
    }
  }
</style>
