---
interface CodeFile {
  name: string;
  icon: 'java' | 'xml';
  content: string;
  lineCount: number;
}

interface Props {
  files: CodeFile[];
  defaultFile?: number;
}

const { files, defaultFile = 0 } = Astro.props;
---

<div class="code-editor" data-default-file={defaultFile}>
  <div class="editor-container">
    <!-- Code Content -->
    <div class="editor-content">
      {files.map((file, index) => (
        <div
          class:list={['code-panel', { active: index === defaultFile }]}
          data-panel-index={index}
        >
          <div class="code-area">
            <pre><code set:html={file.content} /></pre>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const editors = document.querySelectorAll('.code-editor');
    editors.forEach(editor => {
      const panels = editor.querySelectorAll('.code-panel');
    });
  });
</script>

<style>
  .code-editor {
    width: 100%;
  }

  .editor-container {
    background: #1e293b;
    border-radius: 8px;
    overflow: hidden;
    width: 100%;
  }

  .editor-content {
    position: relative;
    background: #1e293b;
    min-height: 380px;
  }

  .code-panel {
    display: none;
    position: absolute;
    inset: 0;
  }

  .code-panel.active {
    display: block;
  }

  .code-area {
    padding: 0.375rem 0.625rem;
    overflow: auto;
  }

  .code-area pre {
    margin: 0;
    font-family: 'JetBrains Mono', 'Fira Code', 'Consolas', monospace;
    font-size: 0.875rem;
    line-height: 1.4;
    color: #a9b7c6;
  }

  .code-area code {
    display: block;
    white-space: pre;
  }

  /* Syntax Highlighting */
  :global(.keyword) { color: #cc7832; font-weight: 500; }
  :global(.string) { color: #6a8759; }
  :global(.annotation) { color: #bbb529; }
  :global(.function) { color: #ffc66d; }
  :global(.class) { color: #a9b7c6; font-weight: 500; }
  :global(.number) { color: #6897bb; }
  :global(.comment) { color: #808080; font-style: italic; }
  :global(.type) { color: #a9b7c6; }

  /* Responsive */
  @media (max-width: 768px) {
    .editor-content {
      min-height: 320px;
    }
    .code-area pre {
      font-size: 0.75rem;
      line-height: 1.35;
    }
    .code-area {
      padding: 0.25rem 0.375rem;
    }
  }
</style>
