    </div>
  </div>
</section>

<script define:vars={{ codeLines }}>
  const codeElement = document.getElementById('typewriter-code');
  const cursor = document.querySelector('.cursor');
  let lineIndex = 0;
  let charIndex = 0;
  let currentLine = '';
  
  function getIndentLevel(line) {
    let indent = 0;
    for (let char of line) {
      if (char === ' ') indent++;
      else break;
    }
    return Math.floor(indent / 4);
  }
  
  function typeNextChar() {
    if (lineIndex >= codeLines.length) {
      // Reset after delay
      setTimeout(() => {
        lineIndex = 0;
        charIndex = 0;
        currentLine = '';
        codeElement.innerHTML = '';
        typeNextChar();
      }, 3000);
      return;
    }
    
    const line = codeLines[lineIndex];
    
    if (charIndex === 0 && lineIndex > 0) {
      codeElement.innerHTML += '\n';
    }
    
    if (charIndex < line.length) {
      const char = line[charIndex];
      currentLine += char;
      
      // Update display with syntax highlighting
      updateDisplay();
      
      charIndex++;
      const delay = char === ' ' ? 30 : Math.random() * 50 + 30;
      setTimeout(typeNextChar, delay);
    } else {
      lineIndex++;
      charIndex = 0;
      currentLine = '';
      setTimeout(typeNextChar, 100);
    }
  }
  
  function updateDisplay() {
    let html = '';
    const lines = codeElement.innerHTML.split('\n');
    
    codeLines.slice(0, lineIndex).forEach((line, idx) => {
      html += highlightLine(line) + '\n';
    });
    
    if (lineIndex < codeLines.length) {
      html += highlightLine(currentLine);
    }
    
    codeElement.innerHTML = html;
  }
  
  function highlightLine(line) {
    // Simple syntax highlighting
    let highlighted = line
      .replace(/(@\w+)/g, '<span class="token-annotation">$1</span>')
      .replace(/(public|class|static|void|return)/g, '<span class="token-keyword">$1</span>')
      .replace(/(String)/g, '<span class="token-type">$1</span>')
      .replace(/(".*?")/g, '<span class="token-string">$1</span>')
      .replace(/(\w+)\s*\(/g, '<span class="token-function">$1</span>(')
      .replace(/(Feat)/g, '<span class="token-class">$1</span>');
    
    // Preserve indentation
    const indentLevel = getIndentLevel(line);
    if (indentLevel > 0) {
      highlighted = '<span class="token-indent">' + '    '.repeat(indentLevel) + '</span>' + highlighted.trimStart();
    }
    
    return highlighted;
  }
  
  // Start typing animation when page loads
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', typeNextChar);
  } else {
    typeNextChar();
  }
</script>

<style>
  .hero-section {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 4rem 1rem;
  }

  .hero-bg {
