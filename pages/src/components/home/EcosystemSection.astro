---
const projects = [
  {
    name: 'smart-socket',
    description: 'Java AIO 实现的支持百万级长连接通信框架',
    href: 'https://smartboot.tech/smart-socket/',
    tag: '核心引擎'
  },
  {
    name: 'smart-servlet',
    description: '提供一个自主可控的轻量级 Tomcat/Undertow 可替代版本，基于 Feat 重新定义下一代 Servlet 容器!',
    href: 'https://smartboot.tech/smart-servlet/',
    tag: 'Web 容器'
  },
  {
    name: 'smart-mqtt',
    description: '一款面向物联网领域的 MQTT 消息中间件产品',
    href: 'https://smartboot.tech/smart-mqtt/',
    tag: '物联网'
  },
  {
    name: 'Redisun',
    description: '基于 smart-socket 开发的轻量级 Redis 客户端，专为 Java 平台设计，支持异步非阻塞 I/O 操作',
    href: 'https://smartboot.tech/redisun/',
    tag: '数据存储'
  }
];
---

<section class="ecosystem-section" id="ecosystem">
  <div class="ecosystem-container">
    <div class="section-header">
      <div class="title-group">
        <span class="section-label">Ecosystem</span>
        <h2 class="section-title">技术生态</h2>
      </div>
      <p class="section-desc">
        smartboot <span class="desc-highlight">技术生态</span>，构建完整解决方案
      </p>
    </div>
    
    <div class="ecosystem-grid">
      {projects.map((project, index) => (
        <a href={project.href} target="_blank" rel="noopener noreferrer" class="ecosystem-card" data-index={index}>
          <div class="card-header">
            <span class="project-tag">{project.tag}</span>
            <svg class="arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M7 17L17 7M17 7H7M17 7V17"/>
            </svg>
          </div>
          <h3>{project.name}</h3>
          <p>{project.description}</p>
          <div class="card-footer">
            <span class="explore-link">了解更多</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .ecosystem-section {
    padding: 4rem 2rem;
    background: #ffffff;
    position: relative;
  }

  .ecosystem-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 3rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid #e2e8f0;
  }

  .title-group {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .section-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #7c3aed;
    padding: 0.375rem 0.75rem;
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.1) 0%, rgba(124, 58, 237, 0.08) 100%);
    border: 1px solid rgba(139, 92, 246, 0.2);
    border-radius: 6px;
  }

  .section-title {
    font-size: 1.625rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #1e293b 0%, #475569 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-desc {
    color: #64748b;
    font-size: 0.95rem;
    margin: 0;
    font-weight: 500;
  }

  .desc-highlight {
    color: #7c3aed;
    font-weight: 700;
  }

  .ecosystem-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .ecosystem-card {
    background: #f8fafc;
    border-radius: 16px;
    padding: 1.75rem;
    border: 1px solid #e2e8f0;
    text-decoration: none;
    color: inherit;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }
  
  .ecosystem-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #8b5cf6, #3b82f6);
    transform: scaleX(0);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ecosystem-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.1);
    border-color: #cbd5e1;
    background: #ffffff;
  }
  
  .ecosystem-card:hover::before {
    transform: scaleX(1);
  }
  
  .ecosystem-card:hover .arrow-icon {
    transform: translate(4px, -4px);
    opacity: 1;
  }
  
  .ecosystem-card:hover .explore-link {
    color: #7c3aed;
  }
  
  .ecosystem-card:hover .explore-link::after {
    transform: translateX(4px);
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  
  .project-tag {
    font-size: 0.7rem;
    padding: 0.25rem 0.625rem;
    background: rgba(139, 92, 246, 0.1);
    color: #7c3aed;
    border-radius: 9999px;
    font-weight: 500;
  }

  .arrow-icon {
    width: 20px;
    height: 20px;
    color: #94a3b8;
    opacity: 0.5;
    transition: all 0.3s ease;
  }

  .ecosystem-card h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: #1e293b;
    margin: 0 0 0.625rem;
    transition: color 0.3s ease;
  }
  
  .ecosystem-card:hover h3 {
    color: #7c3aed;
  }

  .ecosystem-card p {
    color: #64748b;
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0 0 1.25rem;
  }
  
  .card-footer {
    display: flex;
    align-items: center;
  }
  
  .explore-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: #64748b;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    transition: color 0.3s ease;
  }
  
  .explore-link::after {
    content: '→';
    transition: transform 0.3s ease;
  }

  @media (max-width: 768px) {
    .ecosystem-section {
      padding: 3rem 1rem;
    }
    
    .section-header {
      flex-direction: column;
      gap: 0.75rem;
      align-items: flex-start;
    }

    .title-group {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
    
    .section-title {
      font-size: 1.375rem;
    }
    
    .ecosystem-grid {
      grid-template-columns: 1fr;
    }
    
    .ecosystem-card {
      padding: 1.5rem;
    }
  }
</style>
