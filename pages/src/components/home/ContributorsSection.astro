---
const contributors = [
  { name: 'seer', role: '核心维护者', avatar: 'S' },
  { name: 'smartboot', role: '组织', avatar: 'S' },
  { name: '社区贡献者', role: '开发者', avatar: '+' },
];
---

<section class="contributors-section" id="contributors">
  <div class="contributors-container">
    <div class="section-header">
      <div class="section-label">开源社区</div>
      <h2 class="section-title">Contributors</h2>
      <p class="section-subtitle">感谢每一位贡献者的付出</p>
    </div>
    
    <div class="contributors-content">
      <div class="contributors-avatars">
        {contributors.map((contributor, index) => (
          <div class="avatar-item" style={`--delay: ${index * 0.1}s`}>
            <div class="avatar-circle">{contributor.avatar}</div>
            <span class="avatar-name">{contributor.name}</span>
          </div>
        ))}
        <div class="avatar-item more">
          <div class="avatar-circle more-circle">...</div>
          <span class="avatar-name">更多</span>
        </div>
      </div>
      
      <div class="cta-wrapper">
        <p class="cta-text">Feat 的成长离不开每一位开发者的支持与贡献</p>
        <a href="https://github.com/smartboot/feat/graphs/contributors" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
          <svg class="btn-icon" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          <span>查看 GitHub Contributors</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contributors-section {
    background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    padding: 6rem 2rem;
    position: relative;
  }
  
  .contributors-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 200px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #e2e8f0, transparent);
  }

  .contributors-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .section-label {
    display: inline-block;
    padding: 0.375rem 1rem;
    background: rgba(234, 88, 12, 0.1);
    border: 1px solid rgba(234, 88, 12, 0.2);
    border-radius: 9999px;
    font-size: 0.875rem;
    color: #ea580c;
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .section-title {
    font-size: 2.25rem;
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    color: #64748b;
    font-size: 1.125rem;
  }

  .contributors-content {
    text-align: center;
  }
  
  .contributors-avatars {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }
  
  .avatar-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    animation: fadeInUp 0.6s ease-out var(--delay, 0s) both;
  }
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .avatar-circle {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 600;
    box-shadow: 0 4px 12px rgba(30, 41, 59, 0.2);
    transition: all 0.3s ease;
  }
  
  .avatar-item:hover .avatar-circle {
    transform: scale(1.1);
    box-shadow: 0 8px 24px rgba(30, 41, 59, 0.3);
  }
  
  .avatar-circle.more-circle {
    background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
    color: #64748b;
    font-size: 1.25rem;
  }
  
  .avatar-name {
    font-size: 0.875rem;
    color: #475569;
    font-weight: 500;
  }
  
  .cta-wrapper {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 4px 20px -4px rgba(0, 0, 0, 0.05);
  }
  
  .cta-text {
    color: #64748b;
    font-size: 1rem;
    margin: 0 0 1.5rem;
    line-height: 1.6;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    border-radius: 10px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    font-size: 1rem;
  }

  .btn-primary {
    background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
    color: white;
    box-shadow: 0 4px 14px rgba(30, 41, 59, 0.25);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(30, 41, 59, 0.35);
  }

  .btn-icon {
    width: 1.25rem;
    height: 1.25rem;
    fill: currentColor;
  }

  @media (max-width: 768px) {
    .contributors-section {
      padding: 4rem 1rem;
    }
    
    .section-title {
      font-size: 1.875rem;
    }
    
    .contributors-avatars {
      gap: 1rem;
    }
    
    .avatar-circle {
      width: 56px;
      height: 56px;
      font-size: 1.25rem;
    }
    
    .cta-wrapper {
      padding: 1.5rem;
    }
  }
</style>
