---
import PaymentQrCode from '../PaymentQrCode.astro';

const plans = [
  {
    name: '企业版',
    price: '5000',
    currency: '元',
    period: '永久授权',
    featured: true,
    features: ['全部功能模块', '专业技术支持', '5 个文档访问权限', '优先体验新功能', '企业级安全保障'],
    action: { type: 'payment', label: '立即购买' }
  },
  {
    name: '社区版',
    price: '免费',
    period: '面向个人开源项目',
    featured: false,
    features: ['完整开源代码', '全部功能模块', '社区技术支持'],
    action: { type: 'link', label: '申请入口', href: 'https://gitee.com/smartboot/feat/issues/new?template=support_plan_gitee.yml' }
  },
  {
    name: '教育/创业支持',
    price: '免费申请',
    period: '针对特殊群体的优惠计划',
    featured: false,
    features: ['高校教育助力计划', '创业企业扶持计划', 'Gitee 个人开源项目支持', '优先获得学习资源'],
    action: { 
      type: 'dual', 
      links: [
        { label: '创业企业申请', href: 'https://gitee.com/smartboot/feat/issues/new?template=support_plan.yml' },
        { label: '教育机构申请', href: 'https://gitee.com/smartboot/feat/issues/new?template=support_plan_education.yml' }
      ]
    }
  }
];
---

<section class="pricing-section" id="pricing">
  <div class="pricing-container">
    <div class="section-header">
      <div class="title-group">
        <span class="section-label">Pricing</span>
        <h2 class="section-title">定价方案</h2>
      </div>
      <p class="section-desc">
        灵活选择，<span class="desc-highlight">按需付费</span>
      </p>
    </div>
    
    <div class="pricing-grid">
      {plans.map((plan, index) => (
        <div class={`pricing-card ${plan.featured ? 'featured' : ''}`} data-index={index}>
          {plan.featured && <div class="featured-badge">推荐</div>}
          <div class="pricing-header">
            <h3>{plan.name}</h3>
            <div class="pricing-price">
              <span class="price">{plan.price}</span>
              {plan.currency && <span class="currency">{plan.currency}</span>}
            </div>
            <p class="pricing-period">{plan.period}</p>
          </div>
          <ul class="pricing-features">
            {plan.features.map((feature) => (
              <li>
                <span class="check">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                </span>
                <span>{feature}</span>
              </li>
            ))}
          </ul>
          <div class={`pricing-action ${plan.action.type === 'dual' ? 'dual' : ''}`}>
            {plan.action.type === 'payment' && (
              <PaymentQrCode buttonLabel={plan.action.label} />
            )}
            {plan.action.type === 'link' && (
              <a href={plan.action.href} target="_blank" rel="noopener noreferrer" class="btn btn-outline">
                {plan.action.label}
              </a>
            )}
            {plan.action.type === 'dual' && plan.action.links?.map((link) => (
              <a href={link.href} target="_blank" rel="noopener noreferrer" class="btn btn-small">
                {link.label}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pricing-section {
    padding: 4rem 2rem;
    background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
    position: relative;
  }

  .pricing-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 3rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid #e2e8f0;
  }

  .title-group {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .section-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #ea580c;
    padding: 0.375rem 0.75rem;
    background: linear-gradient(135deg, rgba(234, 88, 12, 0.1) 0%, rgba(249, 115, 22, 0.08) 100%);
    border: 1px solid rgba(234, 88, 12, 0.2);
    border-radius: 6px;
  }

  .section-title {
    font-size: 1.625rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #1e293b 0%, #475569 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-desc {
    color: #64748b;
    font-size: 0.95rem;
    margin: 0;
    font-weight: 500;
  }

  .desc-highlight {
    color: #ea580c;
    font-weight: 700;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    align-items: stretch;
  }

  .pricing-card {
    background: #ffffff;
    border-radius: 16px;
    padding: 1.75rem;
    border: 1px solid #e2e8f0;
    position: relative;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
  }
  
  .pricing-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.1);
  }

  .pricing-card.featured {
    border-color: #ea580c;
    border-width: 2px;
    box-shadow: 0 4px 20px -4px rgba(234, 88, 12, 0.15);
  }
  
  .pricing-card.featured:hover {
    box-shadow: 0 20px 40px -12px rgba(234, 88, 12, 0.2);
  }
  
  .featured-badge {
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, #ea580c 0%, #f97316 100%);
    color: #ffffff;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.25rem 0.875rem;
    border-radius: 0 0 8px 8px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pricing-header {
    text-align: center;
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid #f1f5f9;
  }

  .pricing-header h3 {
    font-size: 1.125rem;
    font-weight: 600;
    color: #1e293b;
    margin: 0 0 0.875rem;
  }

  .pricing-price {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.25rem;
    margin-bottom: 0.375rem;
  }

  .price {
    font-size: 2.5rem;
    font-weight: 800;
    color: #1e293b;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .currency {
    font-size: 1rem;
    color: #64748b;
    font-weight: 500;
  }

  .pricing-period {
    color: #64748b;
    font-size: 0.8rem;
    margin: 0;
  }

  .pricing-features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    flex: 1;
  }

  .pricing-features li {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    padding: 0.625rem 0;
    color: #475569;
    font-size: 0.875rem;
    border-bottom: 1px solid #f8fafc;
  }

  .pricing-features li:last-child {
    border-bottom: none;
  }

  .check {
    width: 18px;
    height: 18px;
    color: #16a34a;
    flex-shrink: 0;
    margin-top: 1px;
  }
  
  .check svg {
    width: 100%;
    height: 100%;
  }

  .pricing-action {
    text-align: center;
    margin-top: auto;
  }

  .pricing-action.dual {
    display: flex;
    gap: 0.625rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.25rem;
    border-radius: 10px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    border: none;
    font-size: 0.9rem;
    width: 100%;
    box-sizing: border-box;
  }

  .btn-outline {
    background: transparent;
    color: #2563eb;
    border: 1.5px solid #2563eb;
  }

  .btn-outline:hover {
    background: #eff6ff;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.15);
  }

  .btn-small {
    flex: 1;
    min-width: calc(50% - 0.3125rem);
    padding: 0.625rem 0.875rem;
    font-size: 0.8rem;
    background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
    color: white;
    box-shadow: 0 4px 14px rgba(30, 41, 59, 0.25);
  }

  .btn-small:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(30, 41, 59, 0.35);
  }

  @media (max-width: 1024px) {
    .section-header {
      flex-direction: column;
      gap: 0.75rem;
      align-items: flex-start;
    }

    .title-group {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
    
    .pricing-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      max-width: 480px;
      margin: 0 auto;
    }
    
    .pricing-card.featured {
      grid-column: span 1;
      max-width: none;
      order: -1;
    }
  }

  @media (max-width: 768px) {
    .pricing-section {
      padding: 2.5rem 1rem;
    }
    
    .section-header {
      margin-bottom: 2rem;
      padding-bottom: 1rem;
    }
    
    .section-title {
      font-size: 1.5rem;
    }

    .pricing-grid {
      gap: 1rem;
    }
    
    .pricing-card {
      padding: 1.25rem;
      border-radius: 12px;
    }
    
    .pricing-header {
      margin-bottom: 1rem;
      padding-bottom: 1rem;
    }
    
    .pricing-header h3 {
      font-size: 1rem;
    }
    
    .price {
      font-size: 2rem;
    }
    
    .pricing-features li {
      padding: 0.5rem 0;
      font-size: 0.8125rem;
    }
    
    .btn {
      padding: 0.625rem 1rem;
      font-size: 0.875rem;
    }
  }
  
  @media (max-width: 480px) {
    .pricing-section {
      padding: 2rem 0.75rem;
    }
    
    .section-desc {
      font-size: 0.875rem;
    }
    
    .pricing-card {
      padding: 1rem;
    }
    
    .pricing-header h3 {
      font-size: 0.9375rem;
    }
    
    .price {
      font-size: 1.75rem;
    }
    
    .currency {
      font-size: 0.875rem;
    }
    
    .pricing-period {
      font-size: 0.75rem;
    }
    
    .check {
      width: 16px;
      height: 16px;
    }
    
    .pricing-action.dual {
      flex-direction: column;
      gap: 0.5rem;
    }
    
    .btn-small {
      min-width: 100%;
      padding: 0.625rem;
      font-size: 0.8125rem;
    }
  }
</style>
