---
import PaymentQrCode from '../PaymentQrCode.astro';
---

<section class="pricing-section" id="pricing">
  <div class="pricing-container">
    <div class="section-header">
      <div class="title-group">
        <span class="section-label">License</span>
        <h2 class="section-title">开源协议</h2>
      </div>
      <p class="section-desc">
        Apache 2.0 协议，<span class="desc-highlight">自由商用</span>
      </p>
    </div>
    
    <div class="license-content">
      <div class="license-card">
        <div class="license-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3>Apache License 2.0</h3>
        <p class="license-desc">
          Feat 采用 Apache 2.0 开源协议，您可以自由地使用、修改和分发本软件，包括商业用途，无需支付任何费用。
        </p>
        <ul class="license-features">
          <li>
            <span class="check">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </span>
            <span>免费商用，无需授权</span>
          </li>
          <li>
            <span class="check">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </span>
            <span>源码完全开放</span>
          </li>
          <li>
            <span class="check">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </span>
            <span>支持修改和二次开发</span>
          </li>
          <li>
            <span class="check">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </span>
            <span>社区技术支持</span>
          </li>
        </ul>
      </div>
      
      <div class="sponsor-card">
        <div class="sponsor-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3>企业赞助</h3>
        <p class="sponsor-desc">
          如果 Feat 对您的项目有帮助，欢迎赞助支持项目的持续发展。赞助企业将被记录在项目贡献者名单中。
        </p>
        <div class="sponsor-links">
          <a href="/feat/sponsors/" class="sponsor-link">查看赞助者名单</a>
        </div>
        <div class="sponsor-action">
          <PaymentQrCode buttonLabel="赞助支持" />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .pricing-section {
    padding: 4rem 2rem;
    background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
    position: relative;
  }

  .pricing-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 3rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid #e2e8f0;
  }

  .title-group {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .section-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #16a34a;
    padding: 0.375rem 0.75rem;
    background: linear-gradient(135deg, rgba(22, 163, 74, 0.1) 0%, rgba(34, 197, 94, 0.08) 100%);
    border: 1px solid rgba(22, 163, 74, 0.2);
    border-radius: 6px;
  }

  .section-title {
    font-size: 1.625rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #1e293b 0%, #475569 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-desc {
    color: #64748b;
    font-size: 0.95rem;
    margin: 0;
    font-weight: 500;
  }

  .desc-highlight {
    color: #16a34a;
    font-weight: 700;
  }

  .license-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: stretch;
  }

  .license-card,
  .sponsor-card {
    background: #ffffff;
    border-radius: 16px;
    padding: 2rem;
    border: 1px solid #e2e8f0;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .license-card:hover,
  .sponsor-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.1);
  }

  .license-icon,
  .sponsor-icon {
    width: 48px;
    height: 48px;
    margin-bottom: 1rem;
  }

  .license-icon svg {
    width: 100%;
    height: 100%;
    color: #16a34a;
  }

  .sponsor-icon svg {
    width: 100%;
    height: 100%;
    color: #ea580c;
  }

  .license-card h3,
  .sponsor-card h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: #1e293b;
    margin: 0 0 0.75rem;
  }

  .license-desc,
  .sponsor-desc {
    color: #64748b;
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0 0 1.5rem;
  }

  .license-features {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .license-features li {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    padding: 0.5rem 0;
    color: #475569;
    font-size: 0.875rem;
  }

  .check {
    width: 18px;
    height: 18px;
    color: #16a34a;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .check svg {
    width: 100%;
    height: 100%;
  }

  .sponsor-links {
    margin-bottom: 1rem;
  }

  .sponsor-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: #ea580c;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .sponsor-link:hover {
    color: #c2410c;
    text-decoration: underline;
  }

  .sponsor-action {
    margin-top: auto;
  }

  @media (max-width: 1024px) {
    .section-header {
      flex-direction: column;
      gap: 0.75rem;
      align-items: flex-start;
    }

    .title-group {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .license-content {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      max-width: 600px;
      margin: 0 auto;
    }
  }

  @media (max-width: 768px) {
    .pricing-section {
      padding: 2.5rem 1rem;
    }

    .section-header {
      margin-bottom: 2rem;
      padding-bottom: 1rem;
    }

    .section-title {
      font-size: 1.5rem;
    }

    .license-card,
    .sponsor-card {
      padding: 1.5rem;
      border-radius: 12px;
    }

    .license-card h3,
    .sponsor-card h3 {
      font-size: 1.125rem;
    }

    .license-desc,
    .sponsor-desc {
      font-size: 0.875rem;
    }

    .license-features li {
      padding: 0.4rem 0;
      font-size: 0.8125rem;
    }
  }

  @media (max-width: 480px) {
    .pricing-section {
      padding: 2rem 0.75rem;
    }

    .section-desc {
      font-size: 0.875rem;
    }

    .license-card,
    .sponsor-card {
      padding: 1.25rem;
    }

    .license-icon,
    .sponsor-icon {
      width: 40px;
      height: 40px;
    }

    .license-card h3,
    .sponsor-card h3 {
      font-size: 1rem;
    }

    .check {
      width: 16px;
      height: 16px;
    }
  }
</style>
