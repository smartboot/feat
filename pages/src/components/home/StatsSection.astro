---
import performanceChart from '../../assets/performance.svg';

const highlights = [
  { 
    label: '性能对比', 
    value: '超越 Vert.x',
    desc: '高性能网络框架'
  },
  { 
    label: '开发体验', 
    value: '类 SpringBoot',
    desc: '注解驱动，零配置上手'
  },
  { 
    label: '生态支持', 
    value: 'AI + 云原生',
    desc: '内置 MCP、函数调用等 AI 能力'
  }
];
---

<section class="stats-section" id="performance">
  <div class="stats-container">
    <div class="section-header">
      <div class="title-group">
        <span class="section-label">Performance</span>
        <h2 class="section-title">性能表现</h2>
      </div>
      <p class="section-desc">
        高性能异步处理，轻松应对<span class="desc-highlight">海量并发</span>
      </p>
    </div>
    
    <div class="content-row">
      <div class="chart-column">
        <div class="performance-chart-wrapper">
          <img src={performanceChart.src} alt="Performance Benchmark" class="performance-chart" />
        </div>
      </div>
      
      <div class="highlights-column">
        {highlights.map((item) => (
          <div class="highlight-item">
            <span class="highlight-label">{item.label}</span>
            <span class="highlight-value">{item.value}</span>
            <span class="highlight-desc">{item.desc}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .stats-section {
    background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
    padding: 4rem 2rem;
    position: relative;
  }

  .stats-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 3rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid #e2e8f0;
  }

  .title-group {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .section-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #059669;
    padding: 0.375rem 0.75rem;
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(5, 150, 105, 0.08) 100%);
    border: 1px solid rgba(16, 185, 129, 0.2);
    border-radius: 6px;
  }

  .section-title {
    font-size: 1.625rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #1e293b 0%, #475569 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-desc {
    color: #64748b;
    font-size: 0.95rem;
    margin: 0;
    font-weight: 500;
  }

  .desc-highlight {
    color: #059669;
    font-weight: 700;
  }
  
  .content-row {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 2rem;
    align-items: start;
  }
  
  .chart-column {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .performance-chart-wrapper {
    padding: 1.5rem;
    background: #ffffff;
    border-radius: 16px;
    border: 1px solid #e2e8f0;
    box-shadow: 0 4px 20px -4px rgba(0, 0, 0, 0.05);
    width: 100%;
  }

  .performance-chart {
    width: 100%;
    max-width: 600px;
    height: auto;
    display: block;
    margin: 0 auto;
  }
  
  .highlights-column {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }
  
  .highlight-item {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 1.125rem;
    text-align: left;
    transition: all 0.3s ease;
  }
  
  .highlight-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(0, 0, 0, 0.08);
    border-color: #cbd5e1;
  }
  
  .highlight-label {
    display: block;
    font-size: 0.7rem;
    color: #64748b;
    margin-bottom: 0.375rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }
  
  .highlight-value {
    display: block;
    font-size: 1.125rem;
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 0.25rem;
  }
  
  .highlight-desc {
    display: block;
    font-size: 0.8rem;
    color: #94a3b8;
  }

  @media (max-width: 768px) {
    .stats-section {
      padding: 3rem 1rem;
    }
    
    .section-header {
      flex-direction: column;
      gap: 0.75rem;
      align-items: flex-start;
    }

    .title-group {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
    
    .section-title {
      font-size: 1.375rem;
    }
    
    .content-row {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
    
    .highlights-column {
      gap: 0.75rem;
    }
  }
</style>
