---
import performanceChart from '../../assets/performance.svg';

const highlights = [
  { 
    label: '性能对比', 
    value: '超越 Vert.x',
    desc: '高性能网络框架'
  },
  { 
    label: '开发体验', 
    value: '类 SpringBoot',
    desc: '注解驱动，零配置上手'
  },
  { 
    label: '生态支持', 
    value: 'AI + 云原生',
    desc: '内置 MCP、函数调用等 AI 能力'
  }
];
---

<section class="stats-section" id="performance">
  <div class="stats-container">
    <div class="section-header">
      <div class="section-label">性能数据</div>
      <h2 class="section-title">卓越的性能表现</h2>
      <p class="section-subtitle">高性能异步处理，轻松应对海量并发</p>
    </div>
    
    <div class="content-row">
      <div class="chart-column">
        <div class="performance-chart-wrapper">
          <img src={performanceChart.src} alt="Performance Benchmark" class="performance-chart" />
        </div>
      </div>
      
      <div class="highlights-column">
        {highlights.map((item) => (
          <div class="highlight-item">
            <span class="highlight-label">{item.label}</span>
            <span class="highlight-value">{item.value}</span>
            <span class="highlight-desc">{item.desc}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .stats-section {
    background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
    padding: 6rem 2rem;
    position: relative;
  }

  .stats-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .section-label {
    display: inline-block;
    padding: 0.375rem 1rem;
    background: rgba(16, 185, 129, 0.1);
    border: 1px solid rgba(16, 185, 129, 0.2);
    border-radius: 9999px;
    font-size: 0.875rem;
    color: #059669;
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .section-title {
    font-size: 2.25rem;
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    color: #64748b;
    font-size: 1.125rem;
  }
  
  .content-row {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 2rem;
    align-items: start;
  }
  
  .chart-column {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .performance-chart-wrapper {
    padding: 1.5rem;
    background: #ffffff;
    border-radius: 16px;
    border: 1px solid #e2e8f0;
    box-shadow: 0 4px 20px -4px rgba(0, 0, 0, 0.05);
    width: 100%;
  }

  .performance-chart {
    width: 100%;
    max-width: 600px;
    height: auto;
    display: block;
    margin: 0 auto;
  }
  
  .highlights-column {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .highlight-item {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 1.25rem;
    text-align: left;
    transition: all 0.3s ease;
  }
  
  .highlight-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(0, 0, 0, 0.08);
    border-color: #cbd5e1;
  }
  
  .highlight-label {
    display: block;
    font-size: 0.75rem;
    color: #64748b;
    margin-bottom: 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .highlight-value {
    display: block;
    font-size: 1.25rem;
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 0.25rem;
  }
  
  .highlight-desc {
    display: block;
    font-size: 0.875rem;
    color: #94a3b8;
  }

  @media (max-width: 768px) {
    .stats-section {
      padding: 4rem 1rem;
    }
    
    .section-title {
      font-size: 1.875rem;
    }
    
    .content-row {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    
    .highlights-column {
      gap: 0.75rem;
    }
  }
</style>
