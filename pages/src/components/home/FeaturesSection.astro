---
const features = [
  {
    letter: 'F',
    title: 'ree',
    subtitle: '开源自由',
    color: '#ea580c',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`,
    description: '基于 Apache 2.0 开源协议，免费商用、自由修改。支持企业级应用开发，共建开放生态。'
  },
  {
    letter: 'E',
    title: 'lastic',
    subtitle: '弹性伸缩',
    color: '#16a34a',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>`,
    description: '弹性伸缩架构，轻松应对海量并发请求，支持十万级、百万级 QPS，满足高并发场景需求。'
  },
  {
    letter: 'A',
    title: 'dvanced',
    subtitle: '先进技术',
    color: '#2563eb',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    description: '全面支持 HTTP/1.0、1.1、2.0、WebSocket、SSE、TLS/SSL 等现代 Web 技术，内置路由、文件上传、WAF 等丰富功能。'
  },
  {
    letter: 'T',
    title: 'iny',
    subtitle: '轻量极速',
    color: '#db2777',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
    description: '微内核架构，基于自研 smart-socket 通信引擎。冷启动耗时低于 100ms，极致性能与资源效率的完美平衡。'
  }
];
---

<section class="features-section" id="features">
  <div class="features-container">
    <div class="section-header">
      <div class="title-group">
        <span class="section-label">Features</span>
        <h2 class="section-title">产品特色</h2>
      </div>
      <p class="section-desc">
        <span class="desc-highlight">F</span>ree · 
        <span class="desc-highlight">E</span>lastic · 
        <span class="desc-highlight">A</span>dvanced · 
        <span class="desc-highlight">T</span>iny
      </p>
    </div>
    
    <div class="features-grid">
      {features.map((feature, index) => (
        <div class="feature-card" data-index={index}>
          <div class="feature-icon-wrapper" style={`--feature-color: ${feature.color}`}>
            <div class="feature-icon" set:html={feature.icon}></div>
          </div>
          <div class="feature-header">
            <div class="feature-letter" style={`color: ${feature.color}`}>{feature.letter}</div>
            <div class="feature-titles">
              <h3 class="feature-title">
                <span style={`color: ${feature.color}`}>{feature.letter}</span>{feature.title}
              </h3>
              <span class="feature-subtitle">{feature.subtitle}</span>
            </div>
          </div>
          <p class="feature-description">{feature.description}</p>
          <div class="feature-progress" style={`--progress-color: ${feature.color}`}></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    padding: 4rem 2rem;
    background: #ffffff;
    position: relative;
  }

  .features-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 3rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid #e2e8f0;
  }

  .title-group {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .section-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #ea580c;
    padding: 0.375rem 0.75rem;
    background: linear-gradient(135deg, rgba(234, 88, 12, 0.1) 0%, rgba(249, 115, 22, 0.08) 100%);
    border: 1px solid rgba(234, 88, 12, 0.2);
    border-radius: 6px;
  }

  .section-title {
    font-size: 1.625rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #1e293b 0%, #475569 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-desc {
    color: #64748b;
    font-size: 0.95rem;
    margin: 0;
    font-weight: 500;
  }

  .desc-highlight {
    color: #ea580c;
    font-weight: 700;
    font-size: 1.05rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .feature-card {
    background: #ffffff;
    border-radius: 16px;
    padding: 1.75rem;
    border: 1px solid #e2e8f0;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }
  
  .feature-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--feature-color);
    transform: scaleX(0);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.1);
    border-color: var(--feature-color);
  }
  
  .feature-card:hover::before {
    transform: scaleX(1);
  }
  
  .feature-card:hover .feature-icon-wrapper {
    transform: scale(1.1);
    background: var(--feature-color);
  }
  
  .feature-card:hover .feature-icon {
    color: #ffffff;
  }
  
  .feature-card:hover .feature-progress {
    width: 100%;
  }

  .feature-icon-wrapper {
    width: 52px;
    height: 52px;
    border-radius: 12px;
    background: rgba(var(--feature-color-rgb), 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    transition: all 0.3s ease;
  }

  .feature-icon {
    width: 26px;
    height: 26px;
    color: var(--feature-color);
    transition: color 0.3s ease;
  }
  
  .feature-icon svg {
    width: 100%;
    height: 100%;
  }

  .feature-header {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    margin-bottom: 0.875rem;
  }

  .feature-letter {
    font-size: 2rem;
    font-weight: 800;
    line-height: 1;
    opacity: 0.3;
  }

  .feature-titles {
    flex: 1;
  }

  .feature-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: #1e293b;
    margin: 0 0 0.25rem;
    display: flex;
    align-items: baseline;
  }
  
  .feature-subtitle {
    font-size: 0.8rem;
    color: #64748b;
    font-weight: 400;
  }

  .feature-description {
    color: #475569;
    font-size: 0.875rem;
    line-height: 1.6;
    margin: 0;
  }
  
  .feature-progress {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 3px;
    width: 0;
    background: var(--progress-color);
    transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @media (max-width: 1024px) {
    .section-header {
      flex-direction: column;
      gap: 0.75rem;
      align-items: flex-start;
    }
    
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .features-section {
      padding: 3rem 1rem;
    }
    
    .title-group {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
    
    .section-title {
      font-size: 1.375rem;
    }
    
    .features-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    
    .feature-card {
      padding: 1.5rem;
    }
  }
</style>
